# ============================================================
# Server Configuration
# ============================================================
PORT=3000
NODE_ENV=development

# ============================================================
# Database Configuration
# ============================================================
# Option 1: Local Development (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=myrecipes
DB_USER=postgres
DB_PASS=123456

# Option 2: Heroku/Production (PostgreSQL URL)
# DATABASE_URL=postgresql://user:password@host:port/database
# Note: DATABASE_URL takes precedence over individual DB_* variables

# ============================================================
# Authentication
# ============================================================
# JWT Secret - MUST be changed in production
JWT_SECRET=your_jwt_secret_key_here_change_in_production

# ============================================================
# File Storage Configuration
# ============================================================
# Storage type: 'local' | 'cloudinary' | 's3'
STORAGE_TYPE=local

# --- Local Storage (default) ---
# Stores files in server/public/images
# No additional configuration needed
LOCAL_UPLOADS_DIR=
LOCAL_BASE_URL=/images

# --- Cloudinary ---
# Option A: Heroku addon (auto-set by heroku addons:create cloudinary)
#   Format: cloudinary://API_KEY:API_SECRET@CLOUD_NAME
# CLOUDINARY_URL=cloudinary://your_api_key:your_api_secret@your_cloud_name
#
# Option B: Manual (individual vars — used if CLOUDINARY_URL is not set)
# CLOUDINARY_CLOUD_NAME=your_cloud_name
# CLOUDINARY_API_KEY=your_api_key
# CLOUDINARY_API_SECRET=your_api_secret
# CLOUDINARY_FOLDER=mobile-recipes

# --- AWS S3 ---
# Uncomment and fill if using STORAGE_TYPE=s3
# AWS_S3_BUCKET=your-bucket-name
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your_access_key_id
# AWS_SECRET_ACCESS_KEY=your_secret_access_key
# AWS_S3_FOLDER=uploads/images

# ============================================================
# HTTPS Configuration (optional, for local development)
# ============================================================
# HTTPS_KEY_PATH=path/to/key.pem
# HTTPS_CERT_PATH=path/to/cert.pem
# HTTPS_CA_PATH=path/to/ca.pem

# ============================================================
# CORS Configuration (optional)
# ============================================================
# Comma-separated list of allowed origins (without paths)
# CORS_ORIGINS=http://localhost:5173,https://yourdomain.com

# ============================================================
# Instructions (تعليمات)
# ============================================================

# Local Development:
# ------------------
# 1. Copy this file to .env
# 2. Fill in your local database credentials (DB_*)
# 3. Generate a secure JWT_SECRET: openssl rand -base64 32
# 4. Keep STORAGE_TYPE=local (default)
# 5. Run: npm run dev

# Heroku/Production:
# ------------------
# 1. Set environment variables using Heroku CLI or dashboard:
#    heroku config:set DATABASE_URL='postgresql://...'
#    heroku config:set JWT_SECRET='your_secure_secret'
#    heroku config:set NODE_ENV='production'
# 
# 2. For file storage in production, choose one:
#
#    Option A - Cloudinary (recommended):
#      heroku config:set STORAGE_TYPE=cloudinary
#      heroku config:set CLOUDINARY_CLOUD_NAME=xxx
#      heroku config:set CLOUDINARY_API_KEY=xxx
#      heroku config:set CLOUDINARY_API_SECRET=xxx
#
#    Option B - AWS S3:
#      heroku config:set STORAGE_TYPE=s3
#      heroku config:set AWS_S3_BUCKET=your-bucket
#      heroku config:set AWS_REGION=us-east-1
#      heroku config:set AWS_ACCESS_KEY_ID=xxx
#      heroku config:set AWS_SECRET_ACCESS_KEY=xxx
#
#    Option C - Keep local (not recommended for Heroku):
#      heroku config:set STORAGE_TYPE=local
#      Note: Files will be lost on dyno restart!
#
# 3. Run: npm start