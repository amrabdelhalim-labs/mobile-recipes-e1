{
  "name": "recipes",
  "version": "1.0.0",
  "description": "Ionic app for sharing recipes",
  "license": "MIT",
  "author": "Amr Abdelhalim",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "start": "node app.js",
    "dev": "nodemon app.js",
    "test": "node tests/repositories.test.js",
    "test:e2e": "node tests/api.test.js",
    "test:comprehensive": "node tests/comprehensive.test.js",
    "test:integration": "node tests/integration.test.js",
    "test:storage": "node tests/storage.test.js",
    "test:all": "npm run test && npm run test:comprehensive && npm run test:integration && npm run test:e2e && npm run test:storage",
    "format": "prettier --write \"**/*.js\" --ignore-path .prettierignore",
    "format:check": "prettier --check \"**/*.js\" --ignore-path .prettierignore"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "body-parser": "^2.2.2",
    "cloudinary": "^2.9.0",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "express-validator": "^7.3.1",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.0.2",
    "nodemon": "^3.1.11",
    "pg": "^8.18.0",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.37.7"
  },
  "devDependencies": {
    "morgan": "^1.10.1",
    "prettier": "^3.8.1"
  }
}
